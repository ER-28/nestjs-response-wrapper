{
  "name": "nestjs-response-wrapper",
  "version": "1.0.0",
  "description": "A professional response standardization library for NestJS",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "npm run build && node dist/index.js",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "check": "biome check .",
    "test": "jest",
    "test:cov": "jest --coverage"
  },
  "keywords": [
    "nestjs",
    "response",
    "wrapper",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.24",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
