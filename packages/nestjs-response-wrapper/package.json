{
  "name": "@reysin/nestjs-response-wrapper",
  "version": "1.0.0",
  "description": "A professional response standardization library for NestJS",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/er28/nestjs-response-wrapper.git",
    "directory": "packages/nestjs-response-wrapper"
  },
  "bugs": {
    "url": "https://github.com/er28/nestjs-response-wrapper/issues"
  },
  "homepage": "https://github.com/er28/nestjs-response-wrapper#readme",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "npm run build && node dist/index.js",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "check": "biome check .",
    "test": "jest",
    "test:cov": "jest --coverage",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "keywords": [
    "nestjs",
    "response",
    "wrapper",
    "api",
    "standard-response",
    "interceptor",
    "exception-filter",
    "pagination",
    "typescript",
    "rest-api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "rxjs": "^7.8.2"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/testing": "^10.0.0",
    "@types/jest": "^29.5.2",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.0",
    "jest": "^29.5.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
